RESEND_API_KEY=replace_with_resend_key
ROADLINK_EMAIL_FROM=Roadlink Trip Control <onboarding@resend.dev>

# Supabase production pilot storage/auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key
PASSWORD_PEPPER=replace_with_random_private_string

# Google Sheets readable mirror. Use a Google Apps Script web app URL
# that receives POST JSON and appends rows to the Roadlink spreadsheet.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your_script_id/exec
